#!/usr/bin/env bash
# Provisions the untrusted agent box: bun, the pi coding agent, and the
# identity-token sidecar. Runs on every boot; every step is idempotent.
#
# Bun comes from the npm registry's platform package rather than its GitHub
# release: registry.npmjs.org is reachable over IPv6, github.com is not, and
# a registry tarball is a plain curl away — no node/npm bootstrap needed.
set -euo pipefail
export DEBIAN_FRONTEND=noninteractive

# pi wants fd and ripgrep and downloads them from GitHub releases when
# missing — which times out on this box, since GitHub has no IPv6. Provide
# them from the Debian repos instead (whose mirrors are dual-stack).
# Debian ships fd's binary as fdfind; pi looks for it under its real name.
if ! command -v rg >/dev/null 2>&1 || ! command -v fd >/dev/null 2>&1; then
  apt-get update
  apt-get install -y ripgrep fd-find
  ln -sf /usr/bin/fdfind /usr/local/bin/fd
fi

if ! command -v bun >/dev/null 2>&1; then
  curl -fsSL "https://registry.npmjs.org/@oven/bun-linux-x64/-/bun-linux-x64-${bun_version}.tgz" \
    | tar -xz -C /tmp
  install -m 0755 /tmp/package/bin/bun /usr/local/bin/bun
  rm -rf /tmp/package
  # pi's bin shebang is `#!/usr/bin/env node`; let bun answer to that name.
  ln -sf /usr/local/bin/bun /usr/local/bin/node
fi

BUN_INSTALL=/usr/local bun install -g @earendil-works/pi-coding-agent

mkdir -p /opt/sidecar
cat > /opt/sidecar/sidecar.mjs <<'EOF_SIDECAR'
${sidecar_source}
EOF_SIDECAR

cat > /etc/systemd/system/openrouter-sidecar.service <<'EOF_UNIT'
[Unit]
Description=OpenRouter identity-token sidecar
After=network-online.target
Wants=network-online.target

[Service]
Environment=PROXY_URL=${proxy_url}
Environment=PORT=8787
ExecStart=/usr/local/bin/bun run /opt/sidecar/sidecar.mjs
DynamicUser=yes
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
EOF_UNIT

systemctl daemon-reload
systemctl enable --now openrouter-sidecar.service

# Every account created on this box (OS Login homes come from /etc/skel) gets
# pi pre-pointed at the sidecar, with a key that is deliberately not a key.
mkdir -p /etc/skel/.pi/agent
cat > /etc/skel/.pi/agent/models.json <<'EOF_MODELS'
${models_json}
EOF_MODELS
cat > /etc/skel/.pi/agent/settings.json <<'EOF_SETTINGS'
${settings_json}
EOF_SETTINGS

# OS Login creates a home from /etc/skel at first SSH, which can happen while
# this script is still running — before the files above exist. Self-heal on
# every login so first-login timing doesn't matter.
cat > /etc/profile.d/pi-seed.sh <<'EOF_SEED'
if [ ! -f "$HOME/.pi/agent/models.json" ] && [ -f /etc/skel/.pi/agent/models.json ]; then
  mkdir -p "$HOME/.pi/agent"
  cp /etc/skel/.pi/agent/*.json "$HOME/.pi/agent/"
fi
EOF_SEED
